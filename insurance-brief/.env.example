# Domain Expert — Insurance Newsletter Agent
# Copy this file to .env and fill in your values

ANTHROPIC_API_KEY=
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
NEWSAPI_KEY=

# Optional: override where the newsletter is delivered
# Comma-separated lists are supported.
# If NEWSLETTER_TO is empty, the newsletter is sent to GMAIL_ADDRESS.
NEWSLETTER_TO=
NEWSLETTER_CC=
NEWSLETTER_BCC=
