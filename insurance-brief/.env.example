# Domain Expert — Insurance Newsletter Agent
# Copy this file to .env and fill in your values

# Email delivery (for mailer.py — not yet implemented)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password

# Newsletter recipients (comma-separated)
RECIPIENTS=recipient1@example.com,recipient2@example.com

# Optional: override scrape window (default: 24 hours)
# CUTOFF_HOURS=24
